<view class="page" wx:if="{{proposal}}">
  <view class="section-title">{{pageTitle}}</view>
  <view class="muted">{{pageDesc}}</view>

  <view class="proposal-tip">
    <view class="tip-title">饭局提议</view>
    <view class="muted">点一下只是表达“我想吃”，不会做全群实时统计。</view>
  </view>

  <view class="dish-list">
    <view class="panel dish-item {{item.cardClass}}" wx:for="{{dishes}}" wx:key="id" data-id="{{item.id}}" bindtap="onToggleWant">
      <view class="dish-main">
        <view wx:if="{{isSingle}}" class="proposal-label">就这道</view>
        <view class="dish-title-row">
          <text class="dish-name">{{item.name}}</text>
          <text wx:if="{{item.custom}}" class="custom-badge">自定义</text>
        </view>
        <view class="muted">{{item.city}} · {{item.category}} · {{item.taste}}</view>
      </view>
      <view class="dish-side">
        <view class="want-pill">{{item.wantText}}</view>
        <view wx:if="{{item.showDetail}}" class="detail-link" data-id="{{item.id}}" catchtap="onOpenDishDetail">看看</view>
      </view>
    </view>
  </view>

  <view class="action-row">
    <button class="ghost-button action-button" bindtap="onSpinAgain">转一道菜</button>
    <button class="ghost-button action-button" bindtap="onCreateAgain">重新配菜</button>
  </view>

  <view class="share-panel">
    <view>
      <view class="share-title">{{shareTitle}}</view>
      <view class="muted">{{shareDesc}}</view>
    </view>
    <button class="share-button" open-type="share">发到群聊</button>
  </view>

  <view wx:if="{{addWheelVisible}}" class="add-wheel-mask" catchtap="onCloseAddWheel">
    <view class="add-wheel-panel" catchtap="noop">
      <view class="add-wheel-head">
        <view>
          <view class="add-wheel-title">给这桌再转一道</view>
          <view class="muted">转到以后再决定要不要加进来。</view>
        </view>
        <view class="add-wheel-close" catchtap="onCloseAddWheel">×</view>
      </view>

      <view class="mini-wheel-wrap">
        <view class="mini-plate">
          <view
            class="mini-dish {{item.posClass}} {{item.chosenClass}}"
            wx:for="{{addWheelItems}}"
            wx:key="id"
          >
            <view class="mini-dish-icon">{{item.icon}}</view>
            <view class="mini-dish-name">{{item.shortName}}</view>
          </view>
          <view class="mini-turner" style="transform: translate(-50%, -50%) rotate({{addWheelAngle}}deg);">
            <view class="mini-stick one"></view>
            <view class="mini-stick two"></view>
            <view class="mini-rest"></view>
          </view>
        </view>
      </view>

      <view class="add-wheel-result" wx:if="{{addWheelPicked}}">
        <view class="add-wheel-result-label">转到了</view>
        <view class="add-wheel-result-name">{{addWheelPicked.name}}</view>
      </view>

      <view class="add-wheel-actions">
        <button class="add-wheel-button ghost" bindtap="onRefreshAddWheel">换一批</button>
        <button class="add-wheel-button primary" bindtap="onStartAddWheel">{{addWheelButtonText}}</button>
      </view>
      <button wx:if="{{addWheelPicked}}" class="add-wheel-confirm" bindtap="onAddPickedDish">加进这桌</button>
    </view>
  </view>

  <dish-sheet visible="{{dishSheetVisible}}" dish="{{detailDish}}" bindclose="onCloseDishSheet"></dish-sheet>
</view>
