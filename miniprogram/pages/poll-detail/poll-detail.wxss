.expired {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #2f251f;
  color: #fff;
  text-align: center;
  font-size: 28rpx;
}

.name-panel {
  margin-top: 20rpx;
}

.name-input {
  box-sizing: border-box;
  width: 100%;
  height: 82rpx;
  padding: 0 24rpx;
  border: 2rpx solid #ead8c8;
  border-radius: 22rpx;
  background: #fff;
  font-size: 28rpx;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 26rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border: 2rpx solid transparent;
}

.dish-item.active {
  border-color: #e84f2a;
}

.dish-item.single {
  align-items: flex-start;
  padding: 30rpx;
  background: linear-gradient(180deg, #fff 0%, #fff7f1 100%);
}

.dish-main {
  flex: 1 1 auto;
  min-width: 0;
}

.proposal-label {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff2e7;
  color: #c43f20;
  font-size: 22rpx;
  font-weight: 900;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 800;
}

.dish-item.single .dish-name {
  font-size: 38rpx;
}

.dish-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.custom-badge {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #2f251f;
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
}

.voter-line {
  margin-top: 8rpx;
  color: #8a3e1d;
  font-size: 23rpx;
  font-weight: 700;
}

.count {
  color: #e84f2a;
  font-size: 30rpx;
  font-weight: 800;
}

.dish-side {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.detail-link {
  padding: 7rpx 16rpx;
  border: 2rpx solid #ffd5c1;
  border-radius: 999rpx;
  background: #fff7f1;
  color: #c43f20;
  font-size: 22rpx;
  font-weight: 900;
}

.submit-button {
  margin-top: 24rpx;
}

.share-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border: 2rpx solid #ead8c8;
  border-radius: 24rpx;
  background: #fff;
}

.share-title {
  color: #2f251f;
  font-size: 28rpx;
  font-weight: 900;
}

.share-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 154rpx;
  height: 66rpx;
  min-height: 66rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #f0d4c5;
  border-radius: 999rpx;
  background: #fff7f1;
  color: #e84f2a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.share-button::after {
  border: 0;
}
