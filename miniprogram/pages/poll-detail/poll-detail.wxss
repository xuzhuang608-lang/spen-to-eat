.proposal-tip {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 22rpx;
  background: #fffdf8;
}

.tip-title {
  color: #35261d;
  font-size: 28rpx;
  font-weight: 900;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 26rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border: 2rpx solid transparent;
}

.dish-item.active {
  border-color: #e85d3d;
  background: #fff6f0;
}

.dish-item.single {
  align-items: flex-start;
  padding: 30rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #fff6f0 100%);
}

.dish-main {
  flex: 1 1 auto;
  min-width: 0;
}

.proposal-label {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #bf4e32;
  font-size: 22rpx;
  font-weight: 900;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 800;
}

.dish-item.single .dish-name {
  font-size: 38rpx;
}

.dish-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.custom-badge {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #4a3025;
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
}

.want-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #e85d3d;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.dish-side {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.detail-link {
  padding: 7rpx 16rpx;
  border: 2rpx solid #f4c7b6;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #bf4e32;
  font-size: 22rpx;
  font-weight: 900;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin: 24rpx 0 0;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #fff0e8;
  box-sizing: border-box;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 62rpx;
  min-height: 62rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 18rpx;
  background: transparent;
  color: #7a6a5f;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.action-button:first-child {
  background: #ffe7dc;
  border: 2rpx solid #ee7558;
  color: #e85d3d;
  box-shadow: 0 8rpx 18rpx rgba(232, 93, 61, 0.1);
}

.action-button::after {
  border: 0;
}

.share-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
}

.share-title {
  color: #35261d;
  font-size: 28rpx;
  font-weight: 900;
}

.share-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 154rpx;
  height: 66rpx;
  min-height: 66rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #eccfc1;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #e85d3d;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.share-button::after {
  border: 0;
}

.add-wheel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(53, 38, 29, 0.24);
}

.add-wheel-panel {
  box-sizing: border-box;
  width: 100%;
  padding: 26rpx 28rpx 36rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #fff8ef;
  box-shadow: 0 -18rpx 42rpx rgba(53, 38, 29, 0.18);
}

.add-wheel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.add-wheel-title {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.add-wheel-close {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  background: #fff2ea;
  color: #a26049;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
}

.mini-wheel-wrap {
  margin-top: 22rpx;
}

.mini-plate {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin: 0 auto;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, rgba(255, 253, 246, 0.98) 0 24%, rgba(255, 246, 225, 0.96) 25% 39%, transparent 40%),
    linear-gradient(24deg, transparent 0 45%, rgba(255, 183, 99, 0.16) 46% 54%, transparent 55% 100%),
    linear-gradient(114deg, transparent 0 45%, rgba(255, 213, 139, 0.16) 46% 54%, transparent 55% 100%),
    linear-gradient(204deg, transparent 0 45%, rgba(255, 183, 99, 0.14) 46% 54%, transparent 55% 100%),
    linear-gradient(294deg, transparent 0 45%, rgba(255, 213, 139, 0.14) 46% 54%, transparent 55% 100%),
    radial-gradient(circle at 50% 50%, #fffdf7 0 58%, #ffe6bd 59% 78%, #ff9c58 79% 100%);
  border: 8rpx solid #ffb56f;
  box-shadow:
    inset 0 0 0 10rpx rgba(255, 255, 255, 0.58),
    inset 0 -14rpx 24rpx rgba(255, 153, 78, 0.08),
    0 16rpx 36rpx rgba(214, 118, 61, 0.14);
}

.mini-dish {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 136rpx;
  min-height: 80rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  background: transparent;
  box-shadow: none;
}

.mini-dish.picked {
  width: 136rpx;
  min-height: 136rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 246, 239, 0.66);
  box-shadow:
    inset 0 0 0 3rpx rgba(232, 93, 61, 0.34),
    0 8rpx 18rpx rgba(232, 93, 61, 0.12);
}

.mini-dish-icon {
  font-size: 30rpx;
  line-height: 1;
}

.mini-dish-name {
  max-width: 132rpx;
  margin-top: 5rpx;
  overflow: hidden;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.82);
  color: #2f2119;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-shadow: 0 3rpx 8rpx rgba(214, 118, 61, 0.12);
}

.mini-pos-0 {
  left: 172rpx;
  top: 20rpx;
}

.mini-pos-1 {
  right: 42rpx;
  top: 62rpx;
}

.mini-pos-2 {
  right: 8rpx;
  top: 188rpx;
}

.mini-pos-3 {
  right: 42rpx;
  bottom: 62rpx;
}

.mini-pos-4 {
  left: 172rpx;
  bottom: 20rpx;
}

.mini-pos-5 {
  left: 42rpx;
  bottom: 62rpx;
}

.mini-pos-6 {
  left: 8rpx;
  top: 188rpx;
}

.mini-pos-7 {
  left: 42rpx;
  top: 62rpx;
}

.mini-plate-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 156rpx;
  height: 156rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, #fffdf8 0 48%, #ffe7c7 49% 64%, #fff7eb 65% 100%);
  box-shadow:
    inset 0 0 0 7rpx rgba(255, 255, 255, 0.68),
    inset 0 -9rpx 16rpx rgba(255, 157, 88, 0.08),
    0 10rpx 20rpx rgba(214, 118, 61, 0.12);
}

.mini-rice-bowl-image {
  position: absolute;
  left: 50%;
  top: 54%;
  z-index: 1;
  width: 126rpx;
  height: 126rpx;
  transform: translate(-50%, -50%);
}

.mini-chopsticks-pointer-image {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 154rpx;
  height: 154rpx;
  transform: translate(-50%, -50%);
  transition: transform 1.5s cubic-bezier(0.15, 0.86, 0.18, 1);
  transform-origin: 50% 50%;
}

.add-wheel-result {
  margin: 18rpx auto 0;
  padding: 16rpx 20rpx;
  border: 2rpx solid #f4c7b6;
  border-radius: 22rpx;
  background: #fff6f0;
  text-align: center;
}

.add-wheel-result-label {
  color: #bf4e32;
  font-size: 22rpx;
  font-weight: 900;
}

.add-wheel-result-name {
  margin-top: 6rpx;
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.add-wheel-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #fff0e8;
}

.add-wheel-button,
.add-wheel-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 66rpx;
  min-height: 66rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 18rpx;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.add-wheel-button::after,
.add-wheel-confirm::after {
  border: 0;
}

.add-wheel-button.ghost {
  background: transparent;
  color: #7a6a5f;
}

.add-wheel-button.primary,
.add-wheel-confirm {
  border: 2rpx solid #ee7558;
  background: #ffe7dc;
  color: #e85d3d;
}

.add-wheel-confirm {
  margin-top: 14rpx;
}
