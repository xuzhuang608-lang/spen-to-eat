<view class="page spin-page">
  <view class="spin-head">
    <view>
      <view class="section-title">{{city}}这一桌</view>
      <view class="muted spin-subtitle">先摆 {{candidateDishes.length}} 道看看，不合胃口就换一桌菜，也能自定义菜品。</view>
    </view>
  </view>

  <view wx:if="{{emptyVisible}}" class="empty-panel">
    <view class="empty-title">这座城市的菜单还在整理</view>
    <view class="empty-desc">可以先换个附近城市，或放宽偏好条件再转一次。</view>
    <button class="empty-action" bindtap="onChooseCity">更换城市</button>
  </view>

  <view wx:else>
    <view class="plate-wrap">
      <view class="plate {{spinningClass}}">
        <view class="plate-wheel" style="transform: rotate({{spinAngle}}deg);">
          <block wx:for="{{candidateDishes}}" wx:key="id">
            <view
              class="plate-dish {{item.posClass}} {{item.plateClass}} {{item.spinStateClass}}"
              data-id="{{item.id}}"
              bindtap="onOpenDish"
            >
              <view class="dish-face" style="transform: rotate({{counterSpinAngle}}deg);">
                <view wx:if="{{item.custom}}" class="custom-badge">自选</view>
                <view class="dish-icon">{{item.icon}}</view>
                <view class="dish-title">{{item.shortName}}</view>
              </view>
            </view>
          </block>
        </view>
        <view class="fixed-pointer">
          <view class="pointer-tip"></view>
          <view class="pointer-stem"></view>
          <view class="pointer-dot"></view>
        </view>
        <view class="plate-center">
          <view class="center-copy">饭点</view>
        </view>
      </view>
      <view wx:if="{{pickedName}}" class="spin-result-line">
        <text class="result-prefix">今晚就它了</text>
        <text class="result-name">{{pickedName}}</text>
        <text wx:if="{{jumpingToResult}}" class="result-status">正在打开详情</text>
      </view>
    </view>

    <view class="spin-actions">
      <button class="primary-button spin-button" loading="{{spinning}}" bindtap="onSpin">{{spinButtonText}}</button>
      <button class="secondary-button" bindtap="onRefreshCandidates">换一桌菜</button>
    </view>
  </view>

  <view class="filter-summary">
    <view class="summary-copy">
      <text class="summary-label">当前</text>
      <text class="summary-text">{{filterSummary}}</text>
    </view>
    <button class="adjust-button" bindtap="onToggleFilters">{{filterToggleText}}</button>
  </view>

  <view class="menu-panel" wx:if="{{hasContent}}">
    <view class="menu-head">
      <view>
        <view class="menu-title">这轮先摆这些</view>
        <view class="muted">看中哪道可以点开，不想吃也能换掉。</view>
      </view>
      <button class="add-dish-button" bindtap="onStartCustomReplace">自定义菜品</button>
    </view>
    <view class="menu-list">
      <block wx:for="{{candidateDishes}}" wx:key="id">
        <view
          class="menu-chip {{item.menuStateClass}}"
          data-id="{{item.id}}"
          bindtap="onOpenDish"
        >
          {{item.name}}<text wx:if="{{item.custom}}"> · 自选</text>
        </view>
      </block>
    </view>
  </view>

  <view class="custom-mask" wx:if="{{customMode}}">
    <view class="custom-panel">
      <view class="custom-title">换掉哪一道？</view>
      <view class="muted">点一个不想吃的，换成你想加的。</view>
      <view class="replace-list">
        <block wx:for="{{candidateDishes}}" wx:key="id">
          <view
            class="replace-chip {{item.replaceClass}}"
            data-id="{{item.id}}"
            bindtap="onOpenDish"
          >
            {{item.name}}
          </view>
        </block>
      </view>
      <input class="custom-input" value="{{customName}}" maxlength="8" placeholder="比如：牛肉火锅" bindinput="onInputCustomName" />
      <view class="custom-actions">
        <button class="secondary-button small" bindtap="onCancelCustomReplace">取消</button>
        <button class="primary-button small" bindtap="onConfirmCustomReplace">换上它</button>
      </view>
    </view>
  </view>

  <view class="filter-panel" wx:if="{{filterVisible}}">
    <view class="filter-block">
      <view class="filter-title">避雷</view>
      <view class="chip-row">
        <block wx:for="{{avoidOptions}}" wx:key="label">
          <view
            class="chip {{item.className}}"
            data-value="{{item.label}}"
            bindtap="onToggleAvoid"
          >
            {{item.label}}
          </view>
        </block>
      </view>
    </view>

    <block wx:for="{{optionGroups}}" wx:key="key">
      <view class="filter-block">
        <view class="filter-title">{{item.title}}</view>
        <view class="chip-row">
          <block wx:for="{{item.options}}" wx:for-item="option" wx:key="label">
            <view
              class="chip {{option.className}}"
              data-key="{{item.key}}"
              data-value="{{option.label}}"
              bindtap="onSelectOption"
            >
              {{option.label}}
            </view>
          </block>
        </view>
      </view>
    </block>
  </view>

  <dish-sheet visible="{{dishSheetVisible}}" dish="{{detailDish}}" show-dislike="{{true}}" show-proposal="{{false}}" binddislike="onDislikeDetailDish" bindclose="onCloseDishSheet"></dish-sheet>
</view>
