.spin-page {
  background: #fff8ef;
}

.spin-head {
  margin-bottom: 34rpx;
}

.spin-subtitle {
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.55;
}

.plate-wrap {
  position: relative;
  padding-top: 28rpx;
  padding-bottom: 8rpx;
}

.plate {
  position: relative;
  width: 570rpx;
  height: 570rpx;
  margin: 0 auto;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, rgba(255, 253, 246, 0.98) 0 24%, rgba(255, 246, 225, 0.96) 25% 39%, transparent 40%),
    linear-gradient(24deg, transparent 0 45%, rgba(255, 183, 99, 0.16) 46% 54%, transparent 55% 100%),
    linear-gradient(114deg, transparent 0 45%, rgba(255, 213, 139, 0.16) 46% 54%, transparent 55% 100%),
    linear-gradient(204deg, transparent 0 45%, rgba(255, 183, 99, 0.14) 46% 54%, transparent 55% 100%),
    linear-gradient(294deg, transparent 0 45%, rgba(255, 213, 139, 0.14) 46% 54%, transparent 55% 100%),
    radial-gradient(circle at 50% 50%, #fffdf7 0 58%, #ffe6bd 59% 78%, #ff9c58 79% 100%);
  border: 8rpx solid #ffb56f;
  box-shadow:
    inset 0 0 0 10rpx rgba(255, 255, 255, 0.58),
    inset 0 -16rpx 28rpx rgba(255, 153, 78, 0.08),
    0 18rpx 42rpx rgba(214, 118, 61, 0.14);
  overflow: hidden;
}

.plate-wheel {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  transform-origin: 50% 50%;
  transition: transform 2.2s cubic-bezier(0.13, 0.86, 0.16, 1);
}

.dish-face {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 2.2s cubic-bezier(0.13, 0.86, 0.16, 1);
}

.fixed-pointer {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 5;
  width: 164rpx;
  height: 164rpx;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.pointer-tip {
  position: absolute;
  left: 50%;
  top: -6rpx;
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 56rpx solid #f04e38;
  transform: translateX(-50%);
  filter: drop-shadow(0 6rpx 8rpx rgba(191, 45, 32, 0.18));
}

.pointer-stem {
  position: absolute;
  left: 50%;
  top: 46rpx;
  width: 14rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff735f 0%, #d82921 100%);
  transform: translateX(-50%);
  box-shadow: 0 6rpx 12rpx rgba(191, 45, 32, 0.18);
}

.pointer-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 44rpx;
  height: 44rpx;
  border: 5rpx solid #fff5ee;
  border-radius: 50%;
  background: #e5392d;
  transform: translate(-50%, -50%);
  box-shadow: 0 5rpx 12rpx rgba(191, 45, 32, 0.2);
}

.plate-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.92);
  border: 8rpx solid rgba(255, 228, 197, 0.9);
  transform: translate(-50%, -50%);
  box-shadow: 0 10rpx 20rpx rgba(214, 118, 61, 0.12);
  pointer-events: none;
}

.center-copy {
  margin-top: 38rpx;
  color: #bf4e32;
  font-size: 20rpx;
  font-weight: 900;
}

.plate-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 186rpx;
  height: 186rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, #fffdf8 0 48%, #ffe7c7 49% 64%, #fff7eb 65% 100%);
  color: #35261d;
  box-shadow:
    inset 0 0 0 8rpx rgba(255, 255, 255, 0.68),
    inset 0 -10rpx 18rpx rgba(255, 157, 88, 0.08),
    0 10rpx 22rpx rgba(214, 118, 61, 0.12);
}

.spin-arrow-pointer {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 170rpx;
  height: 170rpx;
  transform: translate(-50%, -50%);
  transition: transform 1.65s cubic-bezier(0.15, 0.86, 0.18, 1);
  transform-origin: 50% 50%;
}

.spin-arrow-head {
  position: absolute;
  left: 50%;
  top: 10rpx;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 42rpx solid #e5392d;
  transform: translateX(-50%);
}

.spin-arrow-tail {
  position: absolute;
  left: 50%;
  top: 48rpx;
  width: 14rpx;
  height: 74rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff735f 0%, #d82921 100%);
  transform: translateX(-50%);
  box-shadow: 0 6rpx 12rpx rgba(191, 45, 32, 0.18);
}

.spin-arrow-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #fff5ee;
  border-radius: 50%;
  background: #e5392d;
  transform: translate(-50%, -50%);
  box-shadow: 0 5rpx 12rpx rgba(191, 45, 32, 0.2);
}

.plate-dish {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 154rpx;
  min-height: 92rpx;
  padding: 8rpx;
  border: 0;
  border-radius: 20rpx;
  background: transparent;
  box-shadow: none;
}

.plate-dish.picked {
  width: 154rpx;
  min-height: 154rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 201, 103, 0.2);
  box-shadow:
    inset 0 0 0 4rpx rgba(255, 209, 112, 0.72),
    0 0 0 10rpx rgba(255, 209, 112, 0.18),
    0 14rpx 26rpx rgba(232, 93, 61, 0.16);
}

.plate-dish.replace-target {
  background: rgba(255, 246, 239, 0.58);
  box-shadow:
    inset 0 0 0 3rpx rgba(232, 93, 61, 0.32),
    0 8rpx 18rpx rgba(232, 93, 61, 0.1);
}

.custom-badge {
  position: absolute;
  top: -8rpx;
  right: -4rpx;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  background: #6d8f42;
  color: #fff;
  font-size: 16rpx;
  font-weight: 900;
}

.spin-result-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin: 20rpx auto 0;
  padding: 0 24rpx;
  color: #35261d;
  text-align: center;
}

.result-prefix {
  color: #bf4e32;
  font-size: 25rpx;
  font-weight: 900;
}

.result-name {
  max-width: 440rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #35261d;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
}

.result-status {
  width: 100%;
  color: #a65334;
  font-size: 20rpx;
  font-weight: 900;
}

.spin-reveal {
  box-sizing: border-box;
  width: 520rpx;
  max-width: 520rpx;
  margin: 18rpx auto 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #bf4e32;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
  border: 2rpx solid #f4c7b6;
  box-shadow: 0 10rpx 22rpx rgba(232, 93, 61, 0.12);
}

.spin-result-panel {
  margin-top: 18rpx;
}

.spin-result-panel .spin-reveal {
  margin-top: 0;
}

.spin-result-actions {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  width: 520rpx;
  max-width: 520rpx;
  margin: 16rpx auto 0;
}

.result-action {
  flex: 1;
  height: 74rpx;
  line-height: 74rpx;
  margin: 0;
  padding: 0;
  border-radius: 22rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.result-action::after {
  border: 0;
}

.result-action.secondary {
  border: 2rpx solid #e8d6c6;
  background: #fff;
  color: #5a463b;
}

.result-action.primary {
  border: 2rpx solid #efb49f;
  background: linear-gradient(180deg, #ee6a4b 0%, #e85d3d 100%);
  color: #fff;
  box-shadow: 0 10rpx 18rpx rgba(232, 93, 61, 0.14);
}

.dish-icon {
  font-size: 34rpx;
  line-height: 1;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.86);
}

.dish-title {
  max-width: 150rpx;
  overflow: hidden;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.82);
  color: #2f2119;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 6rpx;
  box-shadow: 0 3rpx 8rpx rgba(214, 118, 61, 0.12);
  text-shadow: none;
}

.pos-0 {
  left: 208rpx;
  top: 26rpx;
}

.pos-1 {
  right: 62rpx;
  top: 80rpx;
}

.pos-2 {
  right: 16rpx;
  top: 226rpx;
}

.pos-3 {
  right: 62rpx;
  bottom: 80rpx;
}

.pos-4 {
  left: 208rpx;
  bottom: 26rpx;
}

.pos-5 {
  left: 62rpx;
  bottom: 80rpx;
}

.pos-6 {
  left: 16rpx;
  top: 226rpx;
}

.pos-7 {
  left: 62rpx;
  top: 80rpx;
}

.spin-actions {
  display: flex;
  justify-content: center;
  gap: 22rpx;
  margin-top: 38rpx;
}

.secondary-button {
  margin: 0;
  width: 200rpx;
  min-height: 78rpx;
  line-height: 78rpx;
  border: 2rpx solid #f4c7b6;
  border-radius: 22rpx;
  background: #fff6f0;
  color: #bf4e32;
  font-size: 28rpx;
  font-weight: 900;
}

.spin-button {
  margin: 0;
  width: 200rpx;
  min-height: 78rpx;
  line-height: 78rpx;
  border: 2rpx solid #efb49f;
  background:
    linear-gradient(180deg, #ee6a4b 0%, #e85d3d 100%);
  font-size: 28rpx;
  box-shadow: 0 12rpx 24rpx rgba(232, 93, 61, 0.16);
}

.spin-button::after {
  border: 0;
}

.filter-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 34rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 22rpx rgba(78, 52, 39, 0.05);
}

.summary-copy {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1 1 auto;
  min-width: 0;
}

.summary-label {
  flex: 0 0 auto;
  color: #a65334;
  font-size: 24rpx;
  font-weight: 900;
}

.summary-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #6f5f55;
  font-size: 24rpx;
  font-weight: 800;
}

.adjust-button {
  box-sizing: border-box;
  flex: 0 0 160rpx;
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0;
  margin: 0;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #bf4e32;
  font-size: 23rpx;
  font-weight: 900;
  border: 2rpx solid #f4c7b6;
}

.adjust-button::after {
  border: 0;
}

.menu-panel {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 22rpx rgba(78, 52, 39, 0.05);
}

.menu-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.menu-head > view {
  flex: 1 1 auto;
  min-width: 0;
}

.menu-title {
  margin-bottom: 6rpx;
  color: #35261d;
  font-size: 30rpx;
  font-weight: 900;
}

.add-dish-button {
  box-sizing: border-box;
  flex: 0 0 160rpx;
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0 0 0 auto;
  padding: 0;
  border: 2rpx solid #f4c7b6;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #bf4e32;
  font-size: 23rpx;
  font-weight: 900;
}

.add-dish-button::after {
  border: 0;
}

.menu-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.menu-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  padding: 10rpx 10rpx 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #794631;
  font-size: 24rpx;
  font-weight: 800;
}

.menu-chip-name {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-chip-remove {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(191, 78, 50, 0.12);
  color: #bf4e32;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.menu-chip.custom {
  background: #edf7e5;
  color: #47652d;
}

.menu-chip.replace-target {
  background: #ffe4d7;
  color: #bf4e32;
  box-shadow: inset 0 0 0 2rpx rgba(232, 93, 61, 0.22);
}

.custom-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(53, 38, 29, 0.22);
}

.custom-panel {
  box-sizing: border-box;
  width: 100%;
  padding: 28rpx 28rpx 38rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #fff8ef;
  box-shadow: 0 -18rpx 40rpx rgba(53, 38, 29, 0.16);
}

.custom-title {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.replace-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.replace-chip {
  max-width: 100%;
  padding: 12rpx 18rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 999rpx;
  background: #fff;
  color: #5a463b;
  font-size: 24rpx;
  font-weight: 800;
}

.replace-chip.active {
  border-color: #efb49f;
  background: #fff0e8;
  color: #bf4e32;
}

.custom-input {
  box-sizing: border-box;
  width: 100%;
  height: 86rpx;
  margin-top: 22rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 22rpx;
  background: #fff;
  color: #35261d;
  font-size: 28rpx;
}

.custom-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.secondary-button.small,
.primary-button.small {
  flex: 1;
  width: auto;
  min-height: 78rpx;
  line-height: 78rpx;
  font-size: 27rpx;
}

.filter-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fff;
}

.filter-block {
  margin-bottom: 24rpx;
}

.filter-block:last-child {
  margin-bottom: 0;
}

.filter-title {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.loading-panel,
.empty-panel {
  padding: 32rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 26rpx;
  background: #fff;
}

.loading-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.loading-dot {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 18rpx;
  border: 6rpx solid #ffe1d4;
  border-top-color: #e85d3d;
  border-radius: 50%;
  animation: menu-loading 0.9s linear infinite;
}

.loading-title {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.loading-desc {
  margin-top: 12rpx;
  color: #7a6a5f;
  font-size: 26rpx;
  line-height: 1.5;
}

@keyframes menu-loading {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.empty-title {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #7a6a5f;
  font-size: 26rpx;
  line-height: 1.5;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 220rpx;
  height: 64rpx;
  min-height: 64rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border: 2rpx solid #e85d3d;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #e85d3d;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.empty-action::after {
  border: 0;
}
