.search-input {
  box-sizing: border-box;
  width: 100%;
  height: 86rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  font-size: 30rpx;
  border: 2rpx solid #e8d6c6;
}

.empty {
  padding: 42rpx 0;
  color: #7a6a5f;
  text-align: center;
  font-size: 28rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 800;
}

.arrow {
  color: #c55335;
  font-size: 46rpx;
}
