.search-input {
  box-sizing: border-box;
  width: 100%;
  height: 86rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  font-size: 30rpx;
  border: 2rpx solid #e8d6c6;
}

.empty {
  padding: 42rpx 0;
  color: #7a6a5f;
  text-align: center;
  font-size: 28rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.dish-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 800;
}

.source-badge {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.source-badge.current {
  background: #fff0e8;
  color: #e85d3d;
}

.source-badge.local {
  background: #fff6e2;
  color: #9b5b17;
}

.source-badge.nearby {
  background: #e9f6f5;
  color: #22726b;
}

.source-badge.province {
  background: #edf7e5;
  color: #47652d;
}

.source-badge.common {
  background: #f2eee9;
  color: #7a6a5f;
}

.result-hint {
  margin-top: 8rpx;
  color: #a65334;
  font-size: 22rpx;
  font-weight: 800;
}

.arrow {
  color: #c55335;
  font-size: 46rpx;
}
