<view class="page">
  <view class="poll-hero">
    <view>
      <view class="section-title">饭局投票</view>
      <view class="muted">先凑几个想吃的，发群里一起定。</view>
    </view>
  </view>

  <view class="add-box">
    <input class="search-input" value="{{keyword}}" placeholder="输入菜名，比如牛杂、砂锅粥" bindinput="onInput" confirm-type="done" bindconfirm="onAddCandidate" />
    <button class="add-button" bindtap="onAddCandidate">加入</button>
  </view>

  <view class="settings-panel">
    <view class="setting-block">
      <view>
        <view class="setting-title">每人最多投 {{voteLimit}} 个</view>
        <view class="muted">第一版先支持 1-5 个</view>
      </view>
      <slider min="0" max="4" value="{{voteLimit - 1}}" step="1" bindchange="onLimitChange" />
    </view>

    <view class="setting-block display-block">
      <view>
        <view class="setting-title">结果显示方式</view>
        <view class="muted">{{anonymous ? "群里投着玩，不暴露谁选了谁" : "适合小范围认真统计"}}</view>
      </view>
      <view class="segment">
        <view class="segment-item {{anonymous ? 'active' : ''}}" data-mode="anonymous" bindtap="onSelectDisplayMode">只看票数</view>
        <view class="segment-item {{anonymous ? '' : 'active'}}" data-mode="public" bindtap="onSelectDisplayMode">显示投票人</view>
      </view>
    </view>
  </view>

  <view class="candidate-head">
    <view>
      <view class="candidate-title">这顿先从这些选</view>
      <view class="muted">也可以自己加菜，临时想吃什么都能放进来。</view>
    </view>
    <button class="fill-button" bindtap="onFillLocal">来点本地味</button>
  </view>

  <view class="dish-list">
    <view class="dish-item {{selectedMap[item.id] ? 'active' : ''}}" wx:for="{{candidates}}" wx:key="id" data-id="{{item.id}}" bindtap="onToggleDish">
      <view>
        <view class="dish-title-row">
          <text class="dish-name">{{item.name}}</text>
          <text wx:if="{{item.custom}}" class="custom-badge">自定义</text>
        </view>
        <view class="dish-meta">{{item.city}} · {{item.category}} · {{item.taste}}</view>
      </view>
      <view class="select-dot">{{selectedMap[item.id] ? "✓" : ""}}</view>
    </view>
  </view>

  <button class="primary-button create-button" bindtap="onCreatePoll">创建 24 小时投票</button>
</view>
