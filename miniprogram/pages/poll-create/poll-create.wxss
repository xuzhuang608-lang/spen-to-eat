.poll-hero {
  margin-bottom: 18rpx;
}

.poll-hero .section-title {
  margin-top: 10rpx;
  margin-bottom: 8rpx;
}

.add-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  font-size: 27rpx;
  border: 2rpx solid #e8d6c6;
}

.add-button {
  flex: 0 0 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  min-width: 140rpx;
  max-width: 140rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0;
  line-height: 1;
  margin: 0;
  border-radius: 20rpx;
  background: #e85d3d;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-shadow: 0 10rpx 20rpx rgba(232, 93, 61, 0.16);
}

.add-button::after {
  border: 2rpx solid #e85d3d;
}

.custom-hint {
  margin-top: 10rpx;
  color: #82675a;
  font-size: 23rpx;
  line-height: 1.4;
}

.proposal-note {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e8d6c6;
  background: #fffdf8;
  box-shadow: 0 12rpx 34rpx rgba(78, 52, 39, 0.08);
}

.note-title {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 800;
}

.note-clear {
  flex: 0 0 120rpx;
  height: 58rpx;
  min-height: 58rpx;
  width: 120rpx;
  min-width: 120rpx;
  max-width: 120rpx;
  padding: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tips-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.tip-card {
  padding: 20rpx;
  border: 2rpx solid #eadbd0;
  border-radius: 22rpx;
  background: #fffdf8;
}

.tip-title {
  color: #35261d;
  font-size: 26rpx;
  font-weight: 900;
}

.candidate-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.candidate-title {
  color: #35261d;
  font-size: 31rpx;
  font-weight: 900;
}

.selected-panel {
  margin-top: 16rpx;
  padding: 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
}

.selected-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.selected-title {
  color: #35261d;
  font-size: 28rpx;
  font-weight: 900;
}

.clear-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0 24rpx;
  margin: 0;
  border: 2rpx solid #eccfc1;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #e85d3d;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
}

.clear-button::after {
  border: 0;
}

.selected-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.selected-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #35261d;
  font-size: 28rpx;
  font-weight: 800;
}

.chip-source {
  color: #b86a4b;
  font-size: 22rpx;
}

.chip-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f1d8ca;
  color: #84452f;
  font-size: 26rpx;
  line-height: 1;
}

.scope-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #fff0e8;
}

.scope-tab {
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 18rpx;
  color: #7a6a5f;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.scope-tab.active {
  background: #4a3025;
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(53, 38, 29, 0.16);
}

.tool-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-sizing: border-box;
}

.tool-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 0 0 300rpx;
  width: 300rpx;
  min-width: 300rpx;
  max-width: 300rpx;
  height: 68rpx;
  min-height: 68rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-button::after {
  border: 0;
}

.tool-row .tool-button {
  border: 2rpx solid #e85d3d;
}

.primary-tool {
  background: #fff0e8;
  color: #e85d3d;
  box-shadow: none;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-bottom: 104rpx;
}

.empty-candidates {
  margin-top: 18rpx;
  padding: 30rpx 24rpx;
  border: 2rpx dashed #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
}

.empty-title {
  color: #35261d;
  font-size: 30rpx;
  font-weight: 900;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 10rpx 26rpx rgba(78, 52, 39, 0.06);
}

.dish-main {
  flex: 1 1 auto;
  min-width: 0;
}

.dish-item.active {
  border-color: #e85d3d;
  background: #fff6f0;
}

.dish-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.detail-link {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 104rpx;
  height: 46rpx;
  border: 2rpx solid #f4c7b6;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #bf4e32;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.dish-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.dish-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 800;
}

.source-badge {
  flex: 0 0 auto;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #bf4e32;
  font-size: 20rpx;
  font-weight: 800;
}

.source-badge.province {
  background: #eef6e9;
  color: #66864d;
}

.source-badge.common {
  background: #fff4df;
  color: #9b6a21;
}

.source-badge.custom {
  background: #4a3025;
  color: #fff;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 7rpx;
  color: #7a6a5f;
  font-size: 24rpx;
  line-height: 1.35;
}

.select-dot {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border: 3rpx solid #e8d6c6;
  border-radius: 50%;
  color: #fff;
  background: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.dish-item.active .select-dot {
  border-color: #e85d3d;
  background: #e85d3d;
}

.create-button {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 34rpx;
}
