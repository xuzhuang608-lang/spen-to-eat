.poll-hero {
  margin-bottom: 18rpx;
}

.poll-hero .section-title {
  margin-top: 10rpx;
  margin-bottom: 8rpx;
}

.add-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  font-size: 27rpx;
  border: 2rpx solid #e8d6c6;
}

.add-button {
  flex: 0 0 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  min-width: 140rpx;
  max-width: 140rpx;
  height: 72rpx;
  min-height: 72rpx;
  padding: 0;
  line-height: 1;
  margin: 0;
  border-radius: 20rpx;
  background: #e85d3d;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-shadow: 0 10rpx 20rpx rgba(232, 93, 61, 0.16);
}

.add-button::after {
  border: 2rpx solid #e85d3d;
}

.custom-hint {
  margin-top: 10rpx;
  color: #82675a;
  font-size: 23rpx;
  line-height: 1.4;
}

.plan-card {
  margin-top: 18rpx;
  padding: 28rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 34rpx rgba(78, 52, 39, 0.08);
}

.plan-title {
  color: #35261d;
  font-size: 29rpx;
  font-weight: 900;
}

.party-size-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 22rpx;
}

.party-size-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #6f5f55;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.party-size-chip.active {
  border-color: #e85d3d;
  background: #fff0e8;
  color: #e85d3d;
}

.proposal-note {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0;
  border-radius: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.note-title {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 800;
}

.note-clear {
  flex: 0 0 120rpx;
  height: 58rpx;
  min-height: 58rpx;
  width: 120rpx;
  min-width: 120rpx;
  max-width: 120rpx;
  padding: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tips-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.tip-card {
  padding: 20rpx;
  border: 2rpx solid #eadbd0;
  border-radius: 22rpx;
  background: #fffdf8;
}

.tip-title {
  color: #35261d;
  font-size: 26rpx;
  font-weight: 900;
}

.selected-panel {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 2rpx solid #f0ded0;
  border-radius: 22rpx;
  background: #fff8ef;
}

.selected-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.selected-title {
  color: #35261d;
  font-size: 28rpx;
  font-weight: 900;
}

.clear-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0 24rpx;
  margin: 0;
  border: 2rpx solid #eccfc1;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #e85d3d;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
}

.clear-button::after {
  border: 0;
}

.selected-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.selected-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #35261d;
  font-size: 28rpx;
  font-weight: 800;
}

.chip-source {
  color: #b86a4b;
  font-size: 22rpx;
}

.chip-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f1d8ca;
  color: #84452f;
  font-size: 26rpx;
  line-height: 1;
}

.scope-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #fff0e8;
}

.scope-tab {
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 18rpx;
  color: #7a6a5f;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.scope-tab.active {
  background: #4a3025;
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(53, 38, 29, 0.16);
}

.tool-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-sizing: border-box;
}

.tool-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 0 0 300rpx;
  width: 300rpx;
  min-width: 300rpx;
  max-width: 300rpx;
  height: 68rpx;
  min-height: 68rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-button::after {
  border: 0;
}

.tool-row .tool-button {
  border: 2rpx solid #e85d3d;
}

.primary-tool {
  background: #fff0e8;
  color: #e85d3d;
  box-shadow: none;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 26rpx;
  padding-bottom: 104rpx;
}

.empty-candidates {
  margin-top: 26rpx;
  padding: 30rpx 24rpx;
  border: 2rpx dashed #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
}

.empty-title {
  color: #35261d;
  font-size: 30rpx;
  font-weight: 900;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 10rpx 26rpx rgba(78, 52, 39, 0.06);
}

.dish-main {
  flex: 1 1 auto;
  min-width: 0;
}

.dish-item.active {
  border-color: #e85d3d;
  background: #fff6f0;
}

.dish-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.detail-link {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 104rpx;
  height: 46rpx;
  border: 2rpx solid #f4c7b6;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #bf4e32;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.dish-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.dish-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 800;
}

.source-badge {
  flex: 0 0 auto;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #bf4e32;
  font-size: 20rpx;
  font-weight: 800;
}

.source-badge.province {
  background: #eef6e9;
  color: #66864d;
}

.source-badge.common {
  background: #fff4df;
  color: #9b6a21;
}

.source-badge.custom {
  background: #4a3025;
  color: #fff;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 7rpx;
  color: #7a6a5f;
  font-size: 24rpx;
  line-height: 1.35;
}

.select-dot {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border: 3rpx solid #e8d6c6;
  border-radius: 50%;
  color: #fff;
  background: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.dish-item.active .select-dot {
  border-color: #e85d3d;
  background: #e85d3d;
}

.create-button {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 34rpx;
}

.add-wheel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(53, 38, 29, 0.24);
}

.add-wheel-panel {
  box-sizing: border-box;
  width: 100%;
  padding: 26rpx 28rpx 36rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #fff8ef;
  box-shadow: 0 -18rpx 42rpx rgba(53, 38, 29, 0.18);
}

.add-wheel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.add-wheel-title {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.add-wheel-close {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  background: #fff2ea;
  color: #a26049;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
}

.mini-wheel-wrap {
  margin-top: 22rpx;
}

.mini-plate {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin: 0 auto;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, rgba(255, 253, 246, 0.98) 0 24%, rgba(255, 246, 225, 0.96) 25% 39%, transparent 40%),
    linear-gradient(24deg, transparent 0 45%, rgba(255, 183, 99, 0.16) 46% 54%, transparent 55% 100%),
    linear-gradient(114deg, transparent 0 45%, rgba(255, 213, 139, 0.16) 46% 54%, transparent 55% 100%),
    linear-gradient(204deg, transparent 0 45%, rgba(255, 183, 99, 0.14) 46% 54%, transparent 55% 100%),
    linear-gradient(294deg, transparent 0 45%, rgba(255, 213, 139, 0.14) 46% 54%, transparent 55% 100%),
    radial-gradient(circle at 50% 50%, #fffdf7 0 58%, #ffe6bd 59% 78%, #ff9c58 79% 100%);
  border: 8rpx solid #ffb56f;
  box-shadow:
    inset 0 0 0 10rpx rgba(255, 255, 255, 0.58),
    inset 0 -14rpx 24rpx rgba(255, 153, 78, 0.08),
    0 16rpx 36rpx rgba(214, 118, 61, 0.14);
  overflow: hidden;
}

.mini-plate-wheel {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  transform-origin: 50% 50%;
  transition: transform 1.85s cubic-bezier(0.13, 0.86, 0.16, 1);
}

.mini-dish {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 136rpx;
  min-height: 80rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  background: transparent;
  box-shadow: none;
}

.mini-dish.picked {
  width: 136rpx;
  min-height: 136rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 246, 239, 0.66);
  box-shadow:
    inset 0 0 0 3rpx rgba(232, 93, 61, 0.34),
    0 8rpx 18rpx rgba(232, 93, 61, 0.12);
}

.mini-dish-face {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 1.85s cubic-bezier(0.13, 0.86, 0.16, 1);
}

.mini-dish-icon {
  font-size: 30rpx;
  line-height: 1;
}

.mini-dish-name {
  max-width: 132rpx;
  margin-top: 5rpx;
  overflow: hidden;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.82);
  color: #2f2119;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-shadow: 0 3rpx 8rpx rgba(214, 118, 61, 0.12);
}

.mini-pos-0 { left: 172rpx; top: 20rpx; }
.mini-pos-1 { right: 42rpx; top: 62rpx; }
.mini-pos-2 { right: 8rpx; top: 188rpx; }
.mini-pos-3 { right: 42rpx; bottom: 62rpx; }
.mini-pos-4 { left: 172rpx; bottom: 20rpx; }
.mini-pos-5 { left: 42rpx; bottom: 62rpx; }
.mini-pos-6 { left: 8rpx; top: 188rpx; }
.mini-pos-7 { left: 42rpx; top: 62rpx; }

.mini-fixed-pointer {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 5;
  width: 142rpx;
  height: 142rpx;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.mini-pointer-tip {
  position: absolute;
  left: 50%;
  top: -2rpx;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 42rpx solid #f04e38;
  transform: translateX(-50%);
  filter: drop-shadow(0 5rpx 8rpx rgba(191, 45, 32, 0.18));
}

.mini-pointer-stem {
  position: absolute;
  left: 50%;
  top: 34rpx;
  width: 14rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff735f 0%, #d82921 100%);
  transform: translateX(-50%);
  box-shadow: 0 5rpx 10rpx rgba(191, 45, 32, 0.18);
}

.mini-pointer-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 36rpx;
  height: 36rpx;
  border: 5rpx solid #fff5ee;
  border-radius: 50%;
  background: #e5392d;
  transform: translate(-50%, -50%);
  box-shadow: 0 5rpx 12rpx rgba(191, 45, 32, 0.2);
}

.mini-plate-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.92);
  border: 7rpx solid rgba(255, 228, 197, 0.9);
  transform: translate(-50%, -50%);
  box-shadow: 0 10rpx 20rpx rgba(214, 118, 61, 0.12);
  pointer-events: none;
}

.mini-center-copy {
  margin-top: 34rpx;
  color: #bf4e32;
  font-size: 18rpx;
  font-weight: 900;
}

.add-wheel-result-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin: 18rpx auto 0;
  padding: 0 24rpx;
  text-align: center;
}

.add-wheel-result-prefix {
  color: #bf4e32;
  font-size: 24rpx;
  font-weight: 900;
}

.add-wheel-result-name {
  max-width: 390rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #35261d;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
}

.add-wheel-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
}

.add-wheel-button,
.add-wheel-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex: 0 0 300rpx;
  width: 300rpx;
  min-width: 300rpx;
  max-width: 300rpx;
  height: 68rpx;
  min-height: 68rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #e85d3d;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.add-wheel-button::after,
.add-wheel-confirm::after {
  border: 0;
}

.add-wheel-button.ghost {
  background: #fff0e8;
  color: #84452f;
}

.add-wheel-button.primary,
.add-wheel-confirm {
  border-color: #e85d3d;
  background: #fff0e8;
  color: #e85d3d;
}

.add-wheel-confirm {
  margin: 14rpx auto 0;
}
