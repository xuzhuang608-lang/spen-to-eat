.tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: #fffdf8;
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 18rpx;
  color: #7a6a5f;
  font-size: 28rpx;
}

.tab.active {
  background: #4a3025;
  color: #fff;
  font-weight: 700;
}

.manage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
}

.manage-hint {
  color: #9a7665;
  font-size: 24rpx;
}

.edit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 132rpx;
  height: 56rpx;
  min-height: 56rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #f1d8cb;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #84452f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.edit-button::after {
  border: 0;
}

.empty {
  padding: 60rpx 0;
  color: #7a6a5f;
  text-align: center;
  font-size: 28rpx;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 800;
}

.arrow {
  color: #c55335;
  font-size: 46rpx;
}

.delete-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 104rpx;
  height: 54rpx;
  min-height: 54rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #f0b8a8;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #c55335;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.delete-button::after {
  border: 0;
}

.clear-current-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 68rpx;
  min-height: 68rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border: 2rpx solid #f0b8a8;
  border-radius: 18rpx;
  background: #fff6f0;
  color: #c55335;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.clear-current-button::after {
  border: 0;
}

.poll-button {
  margin-top: 28rpx;
}
