.tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: #fffdf8;
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 18rpx;
  color: #7a6a5f;
  font-size: 28rpx;
}

.tab.active {
  background: #4a3025;
  color: #fff;
  font-weight: 700;
}

.tab-desc {
  margin-top: 18rpx;
  color: #7a6a5f;
  font-size: 25rpx;
  font-weight: 800;
}

.manage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 22rpx;
}

.manage-hint {
  flex: 0 0 calc(50% - 7rpx);
  min-width: 0;
  color: #9a7665;
  font-size: 24rpx;
}

.edit-button {
  flex: 0 0 calc(50% - 7rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: calc(50% - 7rpx);
  min-width: 0;
  max-width: none;
  height: 56rpx;
  min-height: 56rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #f1d8cb;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #84452f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.edit-button::after {
  border: 0;
}

.empty-panel {
  margin-top: 24rpx;
  padding: 34rpx 28rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(78, 52, 39, 0.05);
}

.empty-title {
  color: #35261d;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #7a6a5f;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 220rpx;
  height: 70rpx;
  min-height: 70rpx;
  margin: 24rpx auto 0;
  padding: 0;
  border: 2rpx solid #efb49f;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #bf4e32;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.empty-action::after {
  border: 0;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.dish-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.dish-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 800;
}

.arrow {
  color: #c55335;
  font-size: 46rpx;
}

.delete-button {
  flex: 0 0 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 140rpx;
  min-width: 140rpx;
  max-width: 140rpx;
  height: 56rpx;
  min-height: 56rpx;
  padding: 0;
  margin: 0 0 0 auto;
  border: 2rpx solid #f0b8a8;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #c55335;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.delete-button::after {
  border: 0;
}

.clear-current-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 68rpx;
  min-height: 68rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border: 2rpx solid #f0b8a8;
  border-radius: 18rpx;
  background: #fff6f0;
  color: #c55335;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.clear-current-button::after {
  border: 0;
}

.poll-button {
  box-sizing: border-box;
  width: 420rpx;
  min-height: 82rpx;
  margin: 28rpx auto 0;
  padding: 0 30rpx;
  font-size: 28rpx;
  line-height: 1;
  white-space: nowrap;
}
