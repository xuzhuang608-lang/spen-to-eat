.tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: #fffdf8;
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 18rpx;
  color: #7a6a5f;
  font-size: 28rpx;
}

.tab.active {
  background: #4a3025;
  color: #fff;
  font-weight: 700;
}

.empty {
  padding: 60rpx 0;
  color: #7a6a5f;
  text-align: center;
  font-size: 28rpx;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 800;
}

.arrow {
  color: #c55335;
  font-size: 46rpx;
}

.poll-button {
  margin-top: 28rpx;
}
