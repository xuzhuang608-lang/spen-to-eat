<view class="page home">
  <view class="brand">
    <view class="brand-topline">
      <view class="brand-kicker">全国城市特色美食</view>
      <view class="city-pill" bindtap="onChooseCity">{{city}} · {{selectedMeal}} ›</view>
    </view>
    <view class="brand-title">饭点到了，转一下</view>
    <view class="brand-subtitle">不想再问“吃什么”，先让{{city}}本地菜给这一顿一个方向。</view>
  </view>

  <view class="meal-panel">
    <view class="decision-head">
      <view>
        <view class="meal-title">今天吃点什么？</view>
        <view class="meal-subtitle">{{city}} · {{selectedMeal}}</view>
      </view>
      <button class="locate-button" loading="{{locating}}" bindtap="onUseLocation">定位</button>
    </view>
    <view class="meal-grid">
      <block wx:for="{{mealOptions}}" wx:key="key">
        <view
          class="meal-card {{item.className}}"
          data-meal="{{item.key}}"
          bindtap="onSelectMeal"
        >
          <view class="meal-icon">{{item.icon}}</view>
          <view>
            <view class="meal-name">{{item.title}}</view>
            <view class="meal-desc">{{item.subtitle}}</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <button class="primary-button start-button" bindtap="onStartSpin">帮我决定</button>
  <view class="start-hint">先从{{city}}{{selectedMeal}}里挑一桌。</view>

  <view class="assist-row">
    <view class="assist-card" bindtap="onSearch">
      <view class="assist-title">搜索</view>
      <view class="assist-desc">找想吃的菜</view>
    </view>
    <view class="assist-card" bindtap="onCreatePoll">
      <view class="assist-title">饭局</view>
      <view class="assist-desc">发群里挑</view>
    </view>
    <view class="assist-card" bindtap="onFavorite">
      <view class="assist-title">收藏</view>
      <view class="assist-desc">看历史</view>
    </view>
  </view>

  <view class="inspiration-head">
    <view>
      <view class="section-title">今日灵感</view>
      <view class="muted">{{inspiration}}</view>
    </view>
  </view>

  <view class="inspiration-empty" wx:if="{{featuredEmpty}}">
    <view class="empty-title">这座城市的菜单还在整理</view>
    <view class="empty-desc">可以先换个附近城市，或用常见菜先顶上。</view>
    <button class="empty-button" bindtap="onChooseCity">切换城市</button>
  </view>

  <view class="inspiration-grid" wx:else>
    <block wx:for="{{featuredDishes}}" wx:key="id">
      <view
        class="inspiration-card {{item.cardClass}}"
        data-id="{{item.id}}"
        bindtap="onOpenDish"
      >
        <image wx:if="{{item.illustrationSrc}}" class="dish-illustration" src="{{item.illustrationSrc}}" mode="aspectFit"></image>
        <view class="dish-meta">{{item.city}} · {{item.category}} · {{item.taste}}</view>
        <view class="dish-name">{{item.name}}</view>
        <view class="dish-phrase">{{item.phrase}}</view>
        <view class="dish-badges">
          <view class="dish-badge" wx:for="{{item.iconBadges}}" wx:for-item="badge" wx:key="label">
            <text class="badge-icon">{{badge.icon}}</text>
            <text>{{badge.label}}</text>
          </view>
        </view>
        <view class="dish-rating">
          <text class="rating-label">本地特色</text>
          <view class="rating-icons">
            <text class="rating-icon {{iconItem.className}}" wx:for="{{item.ratingItems}}" wx:for-item="iconItem" wx:key="key">{{iconItem.icon}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="home-footer">
    <text class="privacy-link" bindtap="onOpenPrivacy">隐私说明</text>
  </view>

  <view wx:if="{{privacyVisible}}" class="privacy-mask">
    <view class="privacy-sheet">
      <view class="privacy-title">定位前需要你的授权</view>
      <view class="privacy-desc">
        获取位置只用于识别当前城市，帮你推荐附近城市的特色美食。也可以暂不授权，手动选择城市继续使用。
      </view>
      <view class="privacy-contract" bindtap="onOpenPrivacyContract">{{privacyContractName}}</view>
      <view class="privacy-actions">
        <button class="privacy-secondary" bindtap="onRejectPrivacyAuthorization">暂不使用</button>
        <button
          class="privacy-primary"
          open-type="agreePrivacyAuthorization"
          bindagreeprivacyauthorization="onAgreePrivacyAuthorization"
        >同意并继续</button>
      </view>
    </view>
  </view>

  <dish-sheet visible="{{dishSheetVisible}}" dish="{{detailDish}}" bindclose="onCloseDishSheet"></dish-sheet>
</view>
