.home {
  padding-top: 22rpx;
  background: #fff8ef;
}

.brand {
  padding: 28rpx 24rpx 24rpx;
  border-radius: 28rpx;
  background: #4a3025;
  color: #fffdf8;
  box-shadow: 0 18rpx 42rpx rgba(78, 52, 39, 0.13);
}

.brand-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.brand-kicker {
  color: #ffd36b;
  font-size: 23rpx;
  font-weight: 800;
}

.city-pill {
  flex: 0 0 auto;
  max-width: 320rpx;
  padding: 9rpx 17rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 239, 0.14);
  color: #fff8ef;
  font-size: 22rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.city-pill:active {
  opacity: 0.78;
}

.brand-title {
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 900;
}

.brand-subtitle {
  margin-top: 14rpx;
  max-width: 560rpx;
  color: #ffe3d3;
  font-size: 27rpx;
  line-height: 1.45;
}

.decision-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  width: 100%;
  gap: 18rpx;
}

.decision-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.locate-button {
  flex: 0 0 180rpx;
  width: 180rpx;
  min-width: 180rpx;
  max-width: 180rpx;
  margin-left: auto;
  align-self: flex-start;
  height: 58rpx;
  padding: 0 8rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 999rpx;
  background: #fffdf8;
  color: #5a463b;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 54rpx;
  white-space: nowrap;
}

.locate-button::after {
  border: 0;
}

.meal-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fffdf8;
  border: 2rpx solid #e8d6c6;
}

.meal-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 900;
}

.meal-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.meal-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 112rpx;
  padding: 18rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 22rpx;
  background: #fff8ef;
}

.meal-card.active {
  border-color: #e85d3d;
  background: #fff0e8;
  box-shadow: 0 10rpx 24rpx rgba(232, 93, 61, 0.12);
}

.meal-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  font-size: 32rpx;
}

.meal-name {
  font-size: 29rpx;
  line-height: 1.2;
  font-weight: 900;
}

.meal-desc {
  margin-top: 5rpx;
  color: #7a6a5f;
  font-size: 22rpx;
}

.start-button {
  margin-top: 20rpx;
  min-height: 98rpx;
  font-size: 34rpx;
}

.assist-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 32rpx;
}

.assist-card {
  min-height: 86rpx;
  padding: 16rpx 12rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  border: 2rpx solid #e8d6c6;
  text-align: center;
}

.assist-card:active {
  background: #fff8ef;
}

.assist-title {
  font-size: 27rpx;
  font-weight: 900;
}

.assist-desc {
  margin-top: 6rpx;
  color: #7a6a5f;
  font-size: 21rpx;
}

.inspiration-head {
  margin-top: 44rpx;
}

.section-title {
  margin: 0 0 8rpx;
  font-size: 36rpx;
  line-height: 1.15;
  font-weight: 900;
}

.inspiration-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
  padding-bottom: 34rpx;
}

.inspiration-empty {
  margin-top: 18rpx;
  padding: 28rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
}

.empty-title {
  color: #35261d;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #7a6a5f;
  font-size: 25rpx;
  line-height: 1.45;
}

.empty-button {
  margin-top: 20rpx;
  width: 180rpx;
  height: 62rpx;
  border-radius: 999rpx;
  background: #4a3025;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.inspiration-card {
  position: relative;
  min-height: 190rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e8d6c6;
  background: #fffdf8;
  overflow: hidden;
}

.inspiration-card.large {
  grid-column: span 2;
  min-height: 230rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #fff0e8 100%);
  border-color: #efc5ad;
}

.dish-illustration {
  position: absolute;
  right: 10rpx;
  top: 6rpx;
  width: 118rpx;
  height: 118rpx;
  opacity: 0.92;
  pointer-events: none;
}

.inspiration-card.large .dish-illustration {
  right: 18rpx;
  top: 10rpx;
  width: 154rpx;
  height: 154rpx;
}

.dish-meta {
  position: relative;
  z-index: 1;
  max-width: 72%;
  color: #a65334;
  font-size: 22rpx;
  font-weight: 800;
}

.dish-name {
  position: relative;
  z-index: 1;
  max-width: 74%;
  margin-top: 10rpx;
  color: #35261d;
  font-size: 36rpx;
  line-height: 1.15;
  font-weight: 900;
}

.inspiration-card.large .dish-name {
  max-width: 70%;
  font-size: 42rpx;
}

.dish-phrase {
  position: relative;
  z-index: 1;
  max-width: 76%;
  margin-top: 12rpx;
  color: #6f5f55;
  font-size: 24rpx;
  line-height: 1.38;
}

.dish-badges {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.dish-badge {
  display: inline-flex;
  align-items: center;
  gap: 5rpx;
  max-width: 100%;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #fff8ef;
  color: #794631;
  font-size: 20rpx;
  font-weight: 800;
}

.badge-icon {
  font-size: 20rpx;
  line-height: 1;
}

.dish-rating {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 12rpx;
}

.rating-label {
  color: #e85d3d;
  font-size: 22rpx;
  font-weight: 900;
}

.rating-icons {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 128rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #e85d3d;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.rating-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  opacity: 0.22;
  line-height: 1;
}

.rating-icon.active {
  opacity: 1;
}

.home-footer {
  display: flex;
  justify-content: center;
  padding: 4rpx 0 18rpx;
}

.privacy-link {
  color: #7a6a5f;
  font-size: 24rpx;
  text-decoration: underline;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(53, 38, 29, 0.36);
}

.privacy-sheet {
  box-sizing: border-box;
  width: 100%;
  padding: 34rpx 30rpx 46rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #fffdf8;
  box-shadow: 0 -16rpx 42rpx rgba(78, 52, 39, 0.16);
}

.privacy-title {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.privacy-desc {
  margin-top: 14rpx;
  color: #6f5f55;
  font-size: 27rpx;
  line-height: 1.5;
}

.privacy-contract {
  margin-top: 18rpx;
  color: #a65334;
  font-size: 26rpx;
  font-weight: 800;
}

.privacy-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.privacy-secondary,
.privacy-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.privacy-secondary {
  border: 2rpx solid #e8d6c6;
  background: #fff8ef;
  color: #5a463b;
}

.privacy-primary {
  background: #e85d3d;
  color: #fff;
}
