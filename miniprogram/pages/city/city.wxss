.city-page {
  background: #fff8ef;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 22rpx;
}

.search-input {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  height: 82rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 22rpx;
  background: #fff;
  color: #35261d;
  font-size: 28rpx;
}

.clear-button {
  flex: 0 0 auto;
  width: 108rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #4a3025;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.result-block {
  margin-top: 26rpx;
}

.quick-panel {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 22rpx rgba(78, 52, 39, 0.05);
}

.current-city-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx;
  border: 2rpx solid #efc5ad;
  border-radius: 22rpx;
  background: #fff0e8;
}

.current-city-name {
  color: #35261d;
  font-size: 34rpx;
  font-weight: 900;
}

.current-city-desc {
  margin-top: 6rpx;
  color: #7a6a5f;
  font-size: 23rpx;
}

.current-city-action {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #4a3025;
  color: #fffdf8;
  font-size: 23rpx;
  font-weight: 900;
}

.popular-title {
  margin-top: 24rpx;
}

.popular-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.popular-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
  padding: 0 8rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 999rpx;
  background: #fff8ef;
  color: #5a463b;
  font-size: 24rpx;
  font-weight: 800;
}

.province-title {
  margin-top: 28rpx;
  margin-bottom: 18rpx;
}

.block-title {
  margin-bottom: 14rpx;
  color: #35261d;
  font-size: 30rpx;
  font-weight: 900;
}

.province-groups {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.province-group {
  padding: 18rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fff;
}

.letter {
  margin-bottom: 14rpx;
  color: #e85d3d;
  font-size: 28rpx;
  font-weight: 900;
}

.province-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.province-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
  padding: 0 8rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 999rpx;
  background: #fff8ef;
  color: #5a463b;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.province-chip.active {
  border-color: #4a3025;
  background: #4a3025;
  color: #fff;
}

.inline-city-panel {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 2rpx solid #efc5ad;
  border-radius: 26rpx;
  background: #fff0e8;
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.58),
    0 10rpx 22rpx rgba(232, 93, 61, 0.08);
}

.selected-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.city-count {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #d75838;
  font-size: 22rpx;
  font-weight: 900;
  border: 2rpx solid #f4c7b6;
}

.city-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.city-chip {
  min-height: 92rpx;
  padding: 14rpx 10rpx;
  border: 2rpx solid #f0d8c8;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 6rpx 14rpx rgba(122, 72, 36, 0.06);
}

.city-name {
  overflow: hidden;
  color: #35261d;
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.province-name {
  overflow: hidden;
  margin-top: 6rpx;
  color: #7a6a5f;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  padding: 40rpx 0;
  color: #7a6a5f;
  text-align: center;
  font-size: 28rpx;
}
