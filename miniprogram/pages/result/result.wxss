.result-card {
  padding: 44rpx 32rpx;
  border-radius: 32rpx;
  background: #4a3025;
  color: #fffdf8;
}

.city {
  color: #ffd36b;
  font-size: 26rpx;
  font-weight: 700;
}

.dish-name {
  margin-top: 10rpx;
  font-size: 54rpx;
  font-weight: 900;
}

.phrase {
  margin-top: 18rpx;
  color: #ffe3d3;
  font-size: 30rpx;
  line-height: 1.45;
}

.rating {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.16);
  font-size: 34rpx;
}

.rating-label {
  font-size: 26rpx;
  color: #ffe3d3;
}

.detail {
  margin-top: 26rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 800;
}

.tag-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-line text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 24rpx;
}

.desc {
  margin-top: 20rpx;
  color: #5a463b;
  font-size: 29rpx;
  line-height: 1.6;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx 16rpx;
  margin-top: 26rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-sizing: border-box;
}

.compact-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0;
  margin: 0;
  border: 2rpx solid #f1d8cb;
  border-radius: 16rpx;
  background: #fffdf8;
  color: #7b5b4b;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.compact-action:first-child {
  border-color: #f2b8a7;
  background: #fff0e8;
  color: #d9573d;
  box-shadow: 0 8rpx 16rpx rgba(216, 87, 61, 0.08);
}

.compact-action::after {
  border: 0;
}

.related {
  margin-top: 28rpx;
}

.related-title {
  color: #35261d;
  font-size: 31rpx;
  font-weight: 900;
}

.related-list {
  margin-top: 20rpx;
}

.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid #eadbd0;
}

.related-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.related-item:last-child {
  padding-bottom: 0;
}

.related-name {
  color: #35261d;
  font-size: 29rpx;
  font-weight: 900;
}

.related-meta {
  margin-top: 6rpx;
  color: #7a6a5f;
  font-size: 24rpx;
}

.related-index {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 128rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.related-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  opacity: 0.22;
  line-height: 1;
}

.related-icon.active {
  opacity: 1;
}
