.result-card {
  position: relative;
  padding: 44rpx 32rpx;
  border-radius: 32rpx;
  background: #4a3025;
  color: #fffdf8;
  overflow: hidden;
}

.result-illustration {
  position: absolute;
  right: 20rpx;
  top: 14rpx;
  width: 210rpx;
  height: 210rpx;
  opacity: 0.96;
}

.city {
  position: relative;
  z-index: 1;
  max-width: 62%;
  color: #ffd36b;
  font-size: 26rpx;
  font-weight: 700;
}

.dish-name {
  position: relative;
  z-index: 1;
  max-width: 62%;
  margin-top: 10rpx;
  font-size: 54rpx;
  font-weight: 900;
}

.phrase {
  position: relative;
  z-index: 1;
  max-width: 68%;
  margin-top: 18rpx;
  color: #ffe3d3;
  font-size: 30rpx;
  line-height: 1.45;
}

.rating {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.16);
  font-size: 34rpx;
}

.rating-label {
  font-size: 26rpx;
  color: #ffe3d3;
}

.decision-actions {
  margin-top: 24rpx;
}

.accept-button {
  min-height: 98rpx;
  font-size: 34rpx;
}

.secondary-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 16rpx;
}

.secondary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 22rpx;
  background: #fffdf8;
  color: #5a463b;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.secondary-action::after {
  border: 0;
}

.secondary-action:active {
  background: #fff8ef;
}

.utility-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10rpx 26rpx;
  margin-top: 18rpx;
}

.utility-action {
  color: #8a6b5a;
  font-size: 24rpx;
  font-weight: 800;
}

.utility-action:active {
  color: #e85d3d;
}

.detail {
  margin-top: 26rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 800;
}

.tag-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-line text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 24rpx;
}

.desc {
  margin-top: 20rpx;
  color: #5a463b;
  font-size: 29rpx;
  line-height: 1.6;
}

.decision-panel {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
}

.decision-item {
  padding: 22rpx;
  border: 2rpx solid #eadbd0;
  border-radius: 24rpx;
  background: #fffdf8;
}

.decision-title {
  color: #35261d;
  font-size: 28rpx;
  font-weight: 900;
}

.decision-text {
  margin-top: 10rpx;
  color: #6f5b50;
  font-size: 26rpx;
  line-height: 1.55;
}

.safety-note {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff6e9;
  color: #7a5b3a;
  font-size: 24rpx;
  line-height: 1.5;
}

.related {
  margin-top: 28rpx;
}

.related-title {
  color: #35261d;
  font-size: 31rpx;
  font-weight: 900;
}

.related-list {
  margin-top: 20rpx;
}

.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid #eadbd0;
}

.related-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.related-item:last-child {
  padding-bottom: 0;
}

.related-name {
  color: #35261d;
  font-size: 29rpx;
  font-weight: 900;
}

.related-meta {
  margin-top: 6rpx;
  color: #7a6a5f;
  font-size: 24rpx;
}

.related-index {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 128rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.related-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  opacity: 0.22;
  line-height: 1;
}

.related-icon.active {
  opacity: 1;
}
