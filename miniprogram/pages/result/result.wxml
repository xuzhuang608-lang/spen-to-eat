<view class="page" wx:if="{{dish}}">
  <view class="result-card">
    <view class="city">{{dish.city}}</view>
    <view class="dish-name">{{dish.name}}</view>
    <view class="phrase">{{dish.phrase}}</view>
    <view class="rating">
      <text class="rating-label">本地特色指数</text>
      <text>{{rating}}</text>
    </view>
  </view>

  <view class="panel detail">
    <view class="detail-title">适合现在吃吗？</view>
    <view class="tag-line">
      <text>{{dish.category}}</text>
      <text>{{dish.taste}}</text>
      <text wx:for="{{dish.mealTime}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="desc">{{dish.description}}</view>
  </view>

  <view class="action-row main-actions">
    <button class="ghost-button compact-action" bindtap="onSpinAgain">再来一轮</button>
    <button class="ghost-button compact-action" bindtap="onFavorite">{{favoriteText}}</button>
    <button class="ghost-button compact-action" bindtap="onCreatePoll">组个饭局</button>
    <button class="ghost-button compact-action" bindtap="onFeedback">提个建议</button>
  </view>

  <view class="panel related" wx:if="{{relatedDishes.length}}">
    <view class="related-head">
      <view>
        <view class="related-title">同城还可以试试</view>
        <view class="muted">没被这道说服，就换个本地口味。</view>
      </view>
    </view>
    <view class="related-list">
      <block wx:for="{{relatedDishes}}" wx:key="id">
        <view class="related-item" data-id="{{item.id}}" bindtap="onOpenRelated">
          <view>
            <view class="related-name">{{item.name}}</view>
            <view class="related-meta">{{item.taste}} · {{item.category}}</view>
          </view>
          <view class="related-index">
            <text class="related-icon {{iconItem.active ? 'active' : ''}}" wx:for="{{item.ratingItems}}" wx:for-item="iconItem" wx:key="key">{{iconItem.icon}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
