<view class="page" wx:if="{{dish}}">
  <view class="result-card">
    <image wx:if="{{dish.illustrationSrc}}" class="result-illustration" src="{{dish.illustrationSrc}}" mode="aspectFit"></image>
    <view class="city">{{dish.city}}</view>
    <view class="dish-name">{{dish.name}}</view>
    <view class="phrase">{{dish.phrase}}</view>
  </view>

  <view class="panel detail">
    <view class="detail-title">适合现在吃吗？</view>
    <view class="tag-line">
      <text>{{dish.category}}</text>
      <text>{{dish.taste}}</text>
      <text wx:for="{{dish.mealTime}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="desc">{{dish.description}}</view>
    <view class="fit-notes">
      <view class="fit-note" wx:for="{{fitNotes}}" wx:key="*this">
        {{item}}
      </view>
    </view>
  </view>

  <view class="decision-action">
    <button class="primary-button accept-action" bindtap="onAcceptDish">就吃这个</button>
  </view>

  <view class="action-row">
    <button class="ghost-button compact-action" bindtap="onSpinAgain">再转一次</button>
    <button class="ghost-button compact-action" bindtap="onFavorite">{{favoriteText}}</button>
    <button class="ghost-button compact-action" bindtap="onCreatePoll">组个饭局</button>
    <button class="ghost-button compact-action" bindtap="onFeedback">提个建议</button>
  </view>

  <view class="safety-note">口味、忌口和适合场景仅供参考。过敏、清真、素食等需求请以实际食材和个人判断为准。</view>

  <dish-sheet visible="{{dishSheetVisible}}" dish="{{detailDish}}" bindclose="onCloseDishSheet"></dish-sheet>
</view>
