<view class="page" wx:if="{{dish}}">
  <view class="result-card">
    <image wx:if="{{dish.illustrationSrc}}" class="result-illustration" src="{{dish.illustrationSrc}}" mode="aspectFit"></image>
    <view class="city">{{dish.city}}</view>
    <view class="dish-name">{{dish.name}}</view>
    <view class="phrase">{{dish.phrase}}</view>
    <view class="rating">
      <text class="rating-label">本地特色指数</text>
      <text>{{rating}}</text>
    </view>
  </view>

  <view class="decision-actions">
    <button class="primary-button accept-button" bindtap="onAcceptDish">就吃这个</button>
    <view class="secondary-actions">
      <button class="secondary-action" bindtap="onSpinAgain">换一道</button>
      <button class="secondary-action" bindtap="onDislikeDish">这顿不吃</button>
    </view>
    <view class="utility-actions">
      <view class="utility-action" bindtap="onFavorite">{{favoriteText}}</view>
      <view class="utility-action" bindtap="onCreatePoll">组饭局</view>
      <view class="utility-action" bindtap="onFeedback">提建议</view>
    </view>
  </view>

  <view class="panel detail">
    <view class="detail-title">适合现在吃吗？</view>
    <view class="tag-line">
      <text>{{dish.category}}</text>
      <text>{{dish.taste}}</text>
      <text wx:for="{{dish.mealTime}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="desc">{{dish.description}}</view>
  </view>

  <view class="decision-panel">
    <block wx:for="{{decisionCards}}" wx:key="title">
      <view class="decision-item">
        <view class="decision-title">{{item.title}}</view>
        <view class="decision-text">{{item.text}}</view>
      </view>
    </block>
  </view>

  <view class="panel related" wx:if="{{relatedDishes.length}}">
    <view class="related-head">
      <view>
        <view class="related-title">同城还可以试试</view>
        <view class="muted">没被这道说服，就换个本地口味。</view>
      </view>
    </view>
    <view class="related-list">
      <block wx:for="{{relatedDishes}}" wx:key="id">
        <view class="related-item" data-id="{{item.id}}" bindtap="onOpenRelated">
          <view>
            <view class="related-name">{{item.name}}</view>
            <view class="related-meta">{{item.taste}} · {{item.category}}</view>
          </view>
          <view class="related-index">
            <text class="related-icon {{iconItem.className}}" wx:for="{{item.ratingItems}}" wx:for-item="iconItem" wx:key="key">{{iconItem.icon}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="safety-note">口味、忌口和适合场景仅供参考。过敏、清真、素食等需求请以实际食材和个人判断为准。</view>

  <dish-sheet visible="{{dishSheetVisible}}" dish="{{detailDish}}" bindclose="onCloseDishSheet"></dish-sheet>
</view>
