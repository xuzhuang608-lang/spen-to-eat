<view class="page">
  <view class="section-title">给饭点转转一点反馈</view>
  <view class="feedback-note">
    <view class="note-title">{{dishLabel}}</view>
    <view class="note-desc">当前版本会先记录在本机。后续接入云端后，可用于统一处理菜品和标签问题。</view>
  </view>
  <view class="chip-row feedback-type-row">
    <view class="chip {{item.className}}" wx:for="{{typeOptions}}" wx:key="label" data-type="{{item.label}}" bindtap="onSelectType">{{item.label}}</view>
  </view>

  <textarea class="textarea" value="{{content}}" maxlength="300" placeholder="可以简单说说哪里不准，或者你想加什么美食。" bindinput="onInput" />
  <button class="primary-button" bindtap="onSubmit">提交反馈</button>
  <view class="feedback-footer">
    <text class="privacy-link" bindtap="onOpenPrivacy">隐私说明</text>
  </view>
</view>
