.dish-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  display: flex;
  align-items: flex-end;
  background: rgba(53, 38, 29, 0.24);
}

.dish-sheet {
  box-sizing: border-box;
  width: 100%;
  max-height: 86vh;
  padding: 18rpx 28rpx 34rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #fff8ef;
  box-shadow: 0 -18rpx 42rpx rgba(53, 38, 29, 0.18);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #e8d6c6;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.sheet-city {
  color: #a65334;
  font-size: 24rpx;
  font-weight: 900;
}

.sheet-title {
  margin-top: 8rpx;
  color: #35261d;
  font-size: 46rpx;
  line-height: 1.12;
  font-weight: 900;
}

.sheet-close {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #fff0e8;
  color: #84452f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.sheet-phrase {
  margin-top: 18rpx;
  color: #6f5f55;
  font-size: 27rpx;
  line-height: 1.45;
}

.sheet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.sheet-tags text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff0e8;
  color: #84452f;
  font-size: 22rpx;
  font-weight: 800;
}

.sheet-rating {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.rating-label {
  color: #e85d3d;
  font-size: 23rpx;
  font-weight: 900;
}

.rating-icons {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 128rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #fff6f0;
  color: #e85d3d;
  font-size: 22rpx;
  line-height: 1;
}

.rating-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  opacity: 0.22;
  line-height: 1;
}

.rating-icon.active {
  opacity: 1;
}

.sheet-desc {
  margin-top: 20rpx;
  padding: 22rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 24rpx;
  background: #fffdf8;
  color: #5a463b;
  font-size: 27rpx;
  line-height: 1.55;
}

.sheet-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #fff0e8;
}

.sheet-action {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 18rpx;
  background: transparent;
  color: #7a6a5f;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.sheet-action.primary {
  border: 2rpx solid #ee7558;
  background: #ffe7dc;
  color: #e85d3d;
  box-shadow: 0 8rpx 18rpx rgba(232, 93, 61, 0.1);
}

.sheet-action::after {
  border: 0;
}
