<view wx:if="{{showSheet}}" class="dish-sheet-mask" catchtap="onClose">
  <view class="dish-sheet" catchtap="noop">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <view>
        <view class="sheet-city">{{viewDish.city}}</view>
        <view class="sheet-title">{{viewDish.name}}</view>
      </view>
      <image wx:if="{{viewDish.illustrationSrc}}" class="sheet-illustration" src="{{viewDish.illustrationSrc}}" mode="aspectFit"></image>
      <view class="sheet-close" catchtap="onClose">×</view>
    </view>

    <view class="sheet-phrase">{{viewDish.phrase}}</view>

    <view class="sheet-tags">
      <text wx:for="{{viewDish.tagLine}}" wx:key="*this">{{item}}</text>
    </view>

    <view class="sheet-rating">
      <text class="rating-label">本地特色</text>
      <view class="rating-icons">
        <text class="rating-icon {{iconItem.className}}" wx:for="{{viewDish.ratingItems}}" wx:for-item="iconItem" wx:key="key">{{iconItem.icon}}</text>
      </view>
    </view>

    <view class="sheet-desc">{{viewDish.description}}</view>

    <view class="sheet-actions">
      <button class="sheet-action primary" bindtap="onPick">{{pickLabel}}</button>
      <button wx:if="{{showDislike}}" class="sheet-action" bindtap="onDislike">这顿不吃</button>
      <button class="sheet-action" bindtap="onFavorite">{{favoriteLabel}}</button>
      <button wx:if="{{showCopy}}" class="sheet-action" bindtap="onCopyName">就吃这个</button>
      <button wx:if="{{showProposal}}" class="sheet-action" bindtap="onCreateProposal">组个饭局</button>
      <button wx:if="{{showFeedback}}" class="sheet-action" bindtap="onFeedback">提个建议</button>
    </view>
  </view>
</view>
