page {
  min-height: 100vh;
  background: #fff8ef;
  color: #35261d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx 48rpx;
}

.section-title {
  margin: 28rpx 0 16rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.muted {
  color: #7a6a5f;
  font-size: 26rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ee6a4b 0%, #e85d3d 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 32rpx rgba(232, 93, 61, 0.18);
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  border: 2rpx solid #e8d6c6;
  border-radius: 22rpx;
  background: #fffdf8;
  color: #5a463b;
  font-size: 28rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fffdf8;
  border: 2rpx solid #e8d6c6;
  color: #5a463b;
  font-size: 26rpx;
}

.chip.active {
  background: #4a3025;
  border-color: #4a3025;
  color: #fff;
}

.panel {
  border-radius: 24rpx;
  background: #fffdf8;
  padding: 26rpx;
  box-shadow: 0 12rpx 34rpx rgba(78, 52, 39, 0.08);
}
